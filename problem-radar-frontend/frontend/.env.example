# Base URL of your FastAPI backend (uvicorn default shown below).
# CORS is already wide open in api.py (allow_origins=["*"]), so no dev-server
# proxy is needed — the frontend calls this URL directly.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Set to "true" to force the UI onto built-in mock data instead of calling
# the backend. Handy for working on the frontend while uvicorn isn't running.
VITE_USE_MOCKS=false
